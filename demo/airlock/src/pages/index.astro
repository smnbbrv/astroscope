---
import '../styles/index.css';
import Layout from '../../../shared/Layout.astro';
import GenericList from '../components/GenericList';
import ItemList from '../components/ItemList';
import PaymentInfo from '../components/PaymentInfo';
import UserCard from '../components/UserCard';

// simulate a full server-side user object with sensitive fields
const fullUser = {
  name: 'John Doe',
  email: 'john@example.com',
  // these should be STRIPPED by airlock:
  passwordHash: '$2b$10$abc123...',
  sessionToken: 'eyJhbGciOiJIUzI1NiJ9...',
  internalId: 'usr_internal_98765',
  role: 'admin',
  dbConnectionString: 'mongodb://admin:secret@prod-db:27017',
  directDebit: {
    iban: 'DE89 3704 0044 0532 0130 00',
    bic: 'ABCDEFGH',
  },
  creditCards: [
    {
      endsWith: '4242',
      type: 'Visa',
      // should be stripped:
      fullNumber: '4111 1111 1111 4242',
      cvv: '123',
    },
    {
      endsWith: '4243',
      type: 'MasterCard',
      // should be stripped:
      fullNumber: '5500 0000 0000 4243',
      cvv: '321',
    },
  ],
};

// simulate server-side items with extra internal fields
const fullItems = [
  { id: 1, title: 'Public Item 1', internalScore: 0.95, createdBy: 'system' },
  { id: 2, title: 'Public Item 2', internalScore: 0.87, createdBy: 'admin' },
  { id: 3, title: 'Public Item 3', internalScore: 0.72, createdBy: 'system' },
];

// generic component — T extends { id, label }, but server items have extra fields
const genericItems = [
  { id: 1, label: 'Alpha', rank: 99, secret: 'classified' },
  { id: 2, label: 'Beta', rank: 42, secret: 'top-secret' },
];
---

<Layout title="Airlock Demo" package="@astroscope/airlock">
  <p class="text-lg mb-6">
    Strips excess props from hydrated Astro islands — only declared prop fields pass through to the client.
  </p>

  <div class="card bg-base-100 shadow-xl mb-6">
    <div class="card-body">
      <h2 class="card-title">UserCard — Flat Object Stripping</h2>
      <p class="text-sm text-base-content/70 mb-4">
        The server has a full user object with <code>passwordHash</code>, <code>sessionToken</code>,
        <code>dbConnectionString</code>, etc. The <code>UserCard</code> component only declares
        <code>name</code> and <code>email</code> props — airlock strips everything else before serialization.
      </p>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <h3 class="font-semibold mb-2">Server Data (all fields):</h3>
          <pre class="bg-base-300 p-4 rounded-lg overflow-x-auto text-xs"><code>{JSON.stringify(fullUser, null, 2)}</code></pre>
        </div>
        <div>
          <h3 class="font-semibold mb-2">Client Component (stripped):</h3>
          <UserCard
            client:load
            {...fullUser}
          />
        </div>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow-xl mb-6">
    <div class="card-body">
      <h2 class="card-title">ItemList — Array Element Stripping</h2>
      <p class="text-sm text-base-content/70 mb-4">
        Each item has <code>internalScore</code> and <code>createdBy</code> on the server.
        The component only declares <code>id</code> and <code>title</code> — excess fields in each array element are stripped.
      </p>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <h3 class="font-semibold mb-2">Server Data (all fields):</h3>
          <pre class="bg-base-300 p-4 rounded-lg overflow-x-auto text-xs"><code>{JSON.stringify(fullItems, null, 2)}</code></pre>
        </div>
        <div>
          <h3 class="font-semibold mb-2">Client Component (stripped):</h3>
          <ItemList client:visible items={fullItems} heading="Public Items" />
        </div>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow-xl mb-6">
    <div class="card-body">
      <h2 class="card-title">PaymentInfo — Nested Object + Array Stripping</h2>
      <p class="text-sm text-base-content/70 mb-4">
        <code>directDebit</code> is a nested object — <code>bic</code> should be stripped, only <code>iban</code> kept.
        <code>creditCards</code> is an array of objects — <code>fullNumber</code> and <code>cvv</code> should be stripped
        from each element, keeping only <code>endsWith</code> and <code>type</code>.
      </p>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <h3 class="font-semibold mb-2">Server Data (all fields):</h3>
          <pre class="bg-base-300 p-4 rounded-lg overflow-x-auto text-xs"><code>{JSON.stringify({ directDebit: fullUser.directDebit, creditCards: fullUser.creditCards }, null, 2)}</code></pre>
        </div>
        <div>
          <h3 class="font-semibold mb-2">Client Component (stripped):</h3>
          <PaymentInfo
            client:load
            directDebit={fullUser.directDebit}
            creditCards={fullUser.creditCards}
          />
        </div>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow-xl mb-6">
    <div class="card-body">
      <h2 class="card-title">GenericList — Generic Component Stripping</h2>
      <p class="text-sm text-base-content/70 mb-4">
        Component declares <code>{'<T extends { id, label }>'}</code>. Each item has extra
        <code>rank</code> and <code>secret</code> — stripped based on the type constraint.
      </p>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <h3 class="font-semibold mb-2">Server Data (all fields):</h3>
          <pre class="bg-base-300 p-4 rounded-lg overflow-x-auto text-xs"><code>{JSON.stringify(genericItems, null, 2)}</code></pre>
        </div>
        <div>
          <h3 class="font-semibold mb-2">Client Component (stripped):</h3>
          <GenericList client:visible items={genericItems} title="Generic Items" />
        </div>
      </div>
    </div>
  </div>

  <div class="alert alert-info">
    <span>
      View the page source and search for <code>&lt;astro-island&gt;</code> to verify that sensitive fields
      like <code>passwordHash</code> and <code>internalScore</code> are not present in the serialized props.
    </span>
  </div>
</Layout>
